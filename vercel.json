{
  "regions": ["sin1"],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 90
    }
  },
  "rewrites": [
    {
      "source": "/api/crate-api/:path*",
      "destination": "/api/crate-api?path=:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
